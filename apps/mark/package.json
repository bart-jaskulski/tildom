{
  "name": "mark.tildom",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "node scripts/build-service-worker.mjs && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server",
    "preview": "NODE_ENV=production node server-dist/index.js",
    "start": "NODE_ENV=production node server-dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.74",
    "@hono/node-server": "^2.0.11",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tailwindcss/typography": "^0.5.19",
    "@tildom/browser-db": "workspace:*",
    "@tildom/markdownish": "workspace:*",
    "@tildom/node-server": "workspace:*",
    "@tildom/sync-client": "workspace:*",
    "@tildom/ui": "workspace:*",
    "ai": "^5.0.193",
    "hono": "^4.12.23",
    "lucide-solid": "^1.17.0",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.13",
    "vite": "^8.0.14",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@tildom/config": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.7"
  }
}
