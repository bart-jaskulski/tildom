{
  "name": "do.tildom",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build && node ../../scripts/build-pwa.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server",
    "preview": "NODE_ENV=production node server-dist/index.js",
    "start": "NODE_ENV=production node server-dist/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.74",
    "@hono/node-server": "^2.0.11",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tildom/browser-db": "workspace:*",
    "@tildom/node-server": "workspace:*",
    "@tildom/ui": "workspace:*",
    "@types/qrcode": "^1.5.6",
    "ai": "^5.0.193",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "lexorank": "^1.0.5",
    "lucide-solid": "^0.554.0",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.13",
    "ufo": "^1.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@tildom/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.7",
    "workbox-precaching": "^7.4.1"
  },
  "engines": {
    "node": ">=22"
  }
