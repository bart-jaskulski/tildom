{
  "name": "tildom",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev:do": "pnpm --filter do.tildom dev",
    "dev:hey": "pnpm --filter hey.tildom dev",
    "dev:home": "pnpm --filter home.tildom dev",
    "dev:kin": "pnpm --filter kin.tildom dev",
    "dev:mark": "pnpm --filter mark.tildom dev",
    "dev:api": "pnpm --filter @tildom/api dev",
    "dev:sync": "pnpm --filter @tildom/sync dev",
    "build": "pnpm --filter './apps/*' --filter './services/*' build",
    "build:do": "pnpm --filter do.tildom build",
    "build:hey": "pnpm --filter hey.tildom build",
    "build:home": "pnpm --filter home.tildom build",
    "build:kin": "pnpm --filter kin.tildom build",
    "build:mark": "pnpm --filter mark.tildom build",
    "build:api": "pnpm --filter @tildom/api build",
    "build:sync": "pnpm --filter @tildom/sync build",
    "start:api": "pnpm --filter @tildom/api start",
    "test": "pnpm --filter './apps/*' --filter './packages/*' --filter './services/*' test",
    "test:do": "pnpm --filter do.tildom test",
    "test:hey": "pnpm --filter hey.tildom test",
    "test:kin": "pnpm --filter kin.tildom test",
    "test:mark": "pnpm --filter mark.tildom test",
    "typecheck": "pnpm --filter './apps/*' --filter './packages/*' --filter './services/*' typecheck",
    "typecheck:do": "pnpm --filter do.tildom typecheck",
    "typecheck:hey": "pnpm --filter hey.tildom typecheck",
    "typecheck:home": "pnpm --filter home.tildom typecheck",
    "typecheck:kin": "pnpm --filter kin.tildom typecheck",
    "typecheck:mark": "pnpm --filter mark.tildom typecheck",
    "typecheck:sync": "pnpm --filter @tildom/sync typecheck"
  },
  "engines": {
    "node": ">=22"
  }
}
